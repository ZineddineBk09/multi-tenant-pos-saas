# =============================================================================
# Multi-Tenant SaaS POS — Environment Variables
# Copy to .env: cp .env.example .env
# =============================================================================

# --- PostgreSQL (Docker Compose default) ---
DATABASE_URL=postgresql://pos_app:pos_secret@localhost:5432/pos_saas

# --- API Gateway (services/api) ---
JWT_SECRET=change-me-in-production-use-a-long-random-string
PORT=4000
CORS_ORIGIN=http://localhost:3000

# --- Host app — Multi-Zone rewrite targets (apps/web) ---
# Local: point to zone dev servers
# Production: full URLs e.g. https://pos-inventory.vercel.app
INVENTORY_URL=http://localhost:3001
CHECKOUT_URL=http://localhost:3002

# --- All frontend apps ---
NEXT_PUBLIC_API_URL=http://localhost:4000
